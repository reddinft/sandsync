{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {}
  },
  "include": ["src", "app.config.ts"],
  "exclude": ["node_modules", "dist", ".vinxi", ".output"]
}
